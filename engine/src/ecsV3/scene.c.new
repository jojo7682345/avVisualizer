Entity entityTypeCreateInstance(Scene scene, EntityTypeID typeID){
    EntityType* type = MAPPING_GET(scene->types, typeID);
    if(type==NULL) return INVALID_ENTITY;
    LocalEntity localEntity = allocateChunkEntity(scene, type);
    Entity entity = allocateEntityID(scene, localEntity, false);
    return entity;
}